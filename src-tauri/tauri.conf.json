{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DrawOver",
  "version": "0.1.0",
  "identifier": "dev.codecora.drawover",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "DrawOver",
        "fullscreen": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "resizable": false,
        "width": 1920,
        "height": 1080,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    }
  },
  "plugins": {
    "global-shortcut": {}
  }
}
